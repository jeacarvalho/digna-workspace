# Digna Application Environment Variables
# Copy this file to .env and modify as needed

# Server Configuration
DIGNA_PORT=8090

# Data Directory Configuration
# This is where SQLite database files will be stored
# In Docker, this should point to a volume mount
DIGNA_DATA_DIR=/var/lib/digna/data

# Logging Configuration
# Options: debug, info, warn, error
DIGNA_LOG_LEVEL=info

# Docker Compose Configuration
# These are used by docker-compose.yml
COMPOSE_PROJECT_NAME=digna